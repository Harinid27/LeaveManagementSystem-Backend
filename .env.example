PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=your-secure-secret-key-64-chars
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173

# Principal Seed Data (Environment Variables on Render)
PRINCIPAL_NAME=Principal Admin
PRINCIPAL_EMAIL=principal@example.com
PRINCIPAL_PASSWORD=Admin@123
PRINCIPAL_DEPARTMENT=Administration
